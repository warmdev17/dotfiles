gaps inner 8
gaps outer 6

client.focused           $lavender $blue $base  $rosewater $blue
client.focused_inactive  $overlay0 $base $text  $rosewater $base
client.unfocused         $base     $base $text  $rosewater $overlay0
client.urgent            $red      $base $red   $overlay0  $red
client.placeholder       $overlay0 $base $text  $overlay0  $base
client.background        $base

for_window [class="^pavucontrol$"] floating enable, move position center
for_window [class="blueman-manager"] floating enable, sticky enable
for_window [class="^.*"] border pixel 3
for_window [all] title_window_icon on
for_window [all] title_window_icon padding 3px
for_window [class="Microsoft Excel"] border none
