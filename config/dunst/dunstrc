[urgency_low]
    timeout = 5
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#313244"

[urgency_normal]
    timeout = 5
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#b4befe"     

[urgency_critical]
    timeout = 0      
    background = "#1e1e2e"
    foreground = "#f9e2af"
    frame_color = "#f38ba8"
[play_sound_on_all]
    summary = "*"
    script = ~/.local/bin/dunst_sound.sh
